generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String
  telefone  String?
  criadoEm  DateTime @default(now()) @map("criado_em")

  @@map("usuarios")
}

model Cliente {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String
  telefone  String?
  interesse String?
  mensagem  String?
  origem    String   @default("cadastro")
  criadoEm  DateTime @default(now()) @map("criado_em")

  @@map("clientes")
}

model Contato {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String
  telefone  String?
  mensagem  String
  criadoEm  DateTime @default(now()) @map("criado_em")

  @@map("contatos")
}

model Notificacao {
  id         Int       @id @default(autoincrement())
  canal      String
  destinatario String
  assunto    String?
  corpo      String
  origem     String
  status     String    @default("pendente")
  tentativas Int       @default(0)
  erro       String?
  criadoEm   DateTime  @default(now()) @map("criado_em")
  enviadoEm  DateTime? @map("enviado_em")

  @@map("notificacoes")
}
