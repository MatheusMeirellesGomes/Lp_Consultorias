PORT=3000

# Banco de dados (SQLite gerenciado pelo Prisma)
DATABASE_URL="file:../data/lp.sqlite"

# SMTP para envio de e-mails (ex.: Gmail com senha de app, SendGrid, Resend, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# E-mail que recebe as notificações de novos cadastros/contatos (padrão: SMTP_USER)
ADMIN_EMAIL=

# WhatsApp do responsável, que recebe notificação de novo cadastro/contato (formato: 5561999999999)
ADMIN_WHATSAPP=

# WHATSAPP_MOCK=true usa um cliente simulado (loga a mensagem no console do worker).
# Ainda não há integração real com WhatsApp — deixe true por enquanto.
WHATSAPP_MOCK=true
